---
/**
 * Custom homepage — bypasses Starlight layout entirely.
 * Data: src/data/books.ts · src/data/home-config.ts
 * Components: src/components/home/
 */
import { books } from '../data/books';
import {
  sidebarNav, utilityWide, utilitiesSmall, siteStats, userProfile, studyBudget,
} from '../data/home-config';
import BookCard  from '../components/home/BookCard.astro';
import ToolCard  from '../components/home/ToolCard.astro';
import StatsBar  from '../components/home/StatsBar.astro';
import StudyBudget from '../components/home/StudyBudget.astro';

const base = '/medical-site';
---

<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Học liệu Y khoa — Tổng quan</title>
  <meta name="description" content="Thư viện học liệu y khoa cá nhân — đọc offline mọi thiết bị." />
  <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  <!-- Tabler Icons (same version used in the rest of the site) -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.11.0/dist/tabler-icons.min.css" />
</head>

<body>
  <div class="pg">

    <!-- ── LEFT SIDEBAR ─────────────────────────────────────────────── -->
    <aside class="sb">
      <!-- Logo -->
      <a href={`${base}/`} class="logo">
        <div class="logo-leaf">🌿</div>
        <div>
          <div class="logo-name">Học Y</div>
          <div class="logo-sub">Hiểu Y</div>
        </div>
      </a>

      <!-- Nav -->
      <nav class="nav" aria-label="Điều hướng chính">
        {sidebarNav.map(item => (
          <a
            href={item.href}
            class={`nav-item${item.active ? ' active' : ''}`}
            aria-current={item.active ? 'page' : undefined}
          >
            <i class={`ti ${item.icon}`} aria-hidden="true"></i>
            <span>{item.label}</span>
          </a>
        ))}
      </nav>

      <!-- Brand footer -->
      <div class="sb-brand">
        <p class="sb-brand-name">Học Y – Hiểu Y</p>
        <p class="sb-brand-desc">Ứng dụng tri thức chữa lành.</p>
      </div>
    </aside>

    <!-- ── MAIN CONTENT ──────────────────────────────────────────────── -->
    <main class="main">

      <!-- Header -->
      <header class="hdr">
        <div class="hdr-greet">
          <h1 class="greeting">{userProfile.greeting}, {userProfile.name} 👋</h1>
          <p class="greeting-sub">{userProfile.subtext}</p>
        </div>
        <div class="hdr-right">
          <a href={`${base}/books/on-benh-dai-cuong/`} class="search-box" role="search">
            <i class="ti ti-search" aria-hidden="true"></i>
            <span>Tìm kiếm môn học, bài giảng...</span>
          </a>
          <button class="notif-btn" aria-label="Thông báo">
            <i class="ti ti-bell" aria-hidden="true"></i>
          </button>
          <div class="avatar" aria-label={userProfile.name}>
            {userProfile.avatarInitial}
          </div>
        </div>
      </header>

      <StudyBudget budget={studyBudget} />

      <!-- Môn học -->
      <section class="sec" aria-labelledby="sec-books">
        <div class="sec-hdr">
          <i class="ti ti-book-2 sec-icon" aria-hidden="true"></i>
          <h2 class="sec-title" id="sec-books">MÔN HỌC</h2>
          <a href={`${base}/learning-paths/`} class="sec-more">Xem tất cả môn học →</a>
        </div>
        <div class="books-grid">
          {books.map(book => <BookCard book={book} />)}
        </div>
      </section>

      <!-- Công cụ học tập -->
      <section class="sec" aria-labelledby="sec-tools">
        <div class="sec-hdr">
          <i class="ti ti-tools sec-icon" aria-hidden="true"></i>
          <h2 class="sec-title" id="sec-tools">CÔNG CỤ HỌC TẬP</h2>
        </div>

        <!-- Wide lộ trình card -->
        <ToolCard config={utilityWide} variant="wide" />

        <!-- 3 small utility cards -->
        <div class="tools-grid">
          {utilitiesSmall.map(u => <ToolCard config={u} variant="small" />)}
        </div>
      </section>

      <!-- Stats bar -->
      <StatsBar stats={siteStats} />

    </main>
  </div>
</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { font-size: 16px; }
  body {
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: #F5F1EB;
    color: #1a1a1a;
    min-height: 100vh;
  }

  /* ── Page layout ── */
  .pg {
    display: flex;
    min-height: 100vh;
  }

  /* ── Sidebar ── */
  .sb {
    width: 220px;
    min-width: 220px;
    background: #fff;
    display: flex;
    flex-direction: column;
    padding: 1.5rem 1rem 1.25rem;
    position: sticky;
    top: 0;
    height: 100vh;
    overflow-y: auto;
    border-right: 1px solid #EDE9E3;
    z-index: 10;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    margin-bottom: 1.75rem;
    padding: 0 .4rem;
  }
  .logo-leaf { font-size: 2rem; line-height: 1; }
  .logo-name { font-size: .9rem; font-weight: 700; color: #1a1a1a; line-height: 1.2; }
  .logo-sub  { font-size: .68rem; color: #aaa; }

  .nav {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
  }
  .nav-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 12px;
    border-radius: 10px;
    text-decoration: none;
    font-size: .84rem;
    color: #666;
    transition: background .12s, color .12s;
  }
  .nav-item i { font-size: 1.05rem; flex-shrink: 0; }
  .nav-item:hover { background: #F5F1EB; color: #1a1a1a; }
  .nav-item.active { background: #E6F4EE; color: #1D9E75; font-weight: 600; }

  .sb-brand {
    margin-top: 1.5rem;
    background: #F5F1EB;
    border-radius: 12px;
    padding: .85rem 1rem;
  }
  .sb-brand-name { font-size: .78rem; font-weight: 600; color: #444; margin-bottom: 2px; }
  .sb-brand-desc { font-size: .7rem; color: #999; }

  /* ── Main area ── */
  .main {
    flex: 1;
    padding: 2rem 2.25rem 3rem;
    max-width: 960px;
    overflow-x: hidden;
  }

  /* ── Header ── */
  .hdr {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1.5rem;
    margin-bottom: 2.25rem;
    flex-wrap: wrap;
  }
  .greeting     { font-size: 1.55rem; font-weight: 700; color: #1a1a1a; margin-bottom: 4px; }
  .greeting-sub { font-size: .84rem; color: #999; }

  .hdr-right {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }
  .search-box {
    display: flex;
    align-items: center;
    gap: 8px;
    background: #fff;
    border: 1px solid #E8E5DF;
    border-radius: 99px;
    padding: 8px 18px;
    font-size: .8rem;
    color: #bbb;
    text-decoration: none;
    min-width: 210px;
    transition: border-color .15s;
  }
  .search-box:hover { border-color: #ccc; }
  .search-box i { font-size: 1rem; flex-shrink: 0; }

  .notif-btn {
    width: 38px; height: 38px;
    border-radius: 50%;
    background: #fff;
    border: 1px solid #E8E5DF;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.1rem; color: #666; cursor: pointer;
    transition: background .12s;
  }
  .notif-btn:hover { background: #F5F1EB; }

  .avatar {
    width: 38px; height: 38px;
    border-radius: 50%;
    background: linear-gradient(135deg, #1D9E75, #0F6E56);
    color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-size: .85rem; font-weight: 700;
    cursor: pointer; user-select: none;
  }

  /* ── Section ── */
  .sec { margin-bottom: 1.75rem; }
  .sec-hdr {
    display: flex;
    align-items: center;
    gap: 7px;
    margin-bottom: 1rem;
  }
  .sec-icon  { font-size: .95rem; color: #bbb; }
  .sec-title { font-size: .68rem; font-weight: 700; letter-spacing: .1em; color: #bbb; }
  .sec-more  { margin-left: auto; font-size: .8rem; color: #1D9E75; text-decoration: none; }
  .sec-more:hover { text-decoration: underline; }

  /* ── Books grid ── */
  .books-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 14px;
  }

  /* ── Tools grid ── */
  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
    gap: 12px;
    margin-top: 12px;
  }

  /* ── Mobile ── */
  @media (max-width: 820px) {
    .sb {
      position: fixed;
      left: -220px;
      transition: left .25s;
      z-index: 100;
    }
    .main { padding: 1.25rem 1rem 2.5rem; }
    .greeting { font-size: 1.25rem; }
    .search-box { min-width: 160px; }
  }

  @media (max-width: 540px) {
    .hdr { gap: .75rem; }
    .hdr-right { flex-wrap: wrap; }
    .search-box { min-width: 100%; }
    .books-grid { grid-template-columns: 1fr; }
    .tools-grid { grid-template-columns: 1fr 1fr; }
  }
</style>
