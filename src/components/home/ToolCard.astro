---
import type { WideUtil, SmallUtil } from '~/data/home-config';

interface Props {
  config: WideUtil | SmallUtil;
  variant: 'wide' | 'small';
}
const { config, variant } = Astro.props;
const wide = config as WideUtil;
const small = config as SmallUtil;
---

{variant === 'wide' ? (
  <a
    href={wide.href}
    class="tw"
    style={`--bg:${wide.cardBg}; --ic:${wide.iconColor}; --ib:${wide.iconBg}; --cb:${wide.ctaBorder}; --cc:${wide.ctaColor};`}
  >
    <!-- Decorative road illustration -->
    <div class="tw-illus" aria-hidden="true">
      <svg viewBox="0 0 200 120" xmlns="http://www.w3.org/2000/svg" fill="none">
        <path d="M 10 110 Q 100 40 190 20" stroke="#854F0B" stroke-width="3" stroke-dasharray="8 5" opacity=".25"/>
        <circle cx="185" cy="22" r="10" fill="#854F0B" opacity=".2"/>
        <circle cx="185" cy="22" r="5"  fill="#854F0B" opacity=".35"/>
        <circle cx="30"  cy="98" r="6"  fill="#854F0B" opacity=".18"/>
        <circle cx="90"  cy="58" r="4"  fill="#854F0B" opacity=".18"/>
        <circle cx="145" cy="34" r="4"  fill="#854F0B" opacity=".18"/>
      </svg>
    </div>

    <!-- Icon -->
    <div class="tw-icon">
      <i class={`ti ${wide.icon}`} aria-hidden="true"></i>
    </div>

    <!-- Body -->
    <div class="tw-body">
      <div class="tw-name">{wide.name}</div>
      <div class="tw-desc">{wide.desc}</div>
    </div>

    <!-- CTA button -->
    <div class="tw-cta">{wide.cta} →</div>
  </a>
) : (
  <a href={small.href} class="ts">
    <div class="ts-icon" style={`background:${small.iconBg}; color:${small.iconColor};`}>
      <i class={`ti ${small.icon}`} aria-hidden="true"></i>
    </div>
    <div class="ts-name">{small.name}</div>
    <div class="ts-desc">{small.desc}</div>
    <div class="ts-stat">{small.stat}</div>
    <div class="ts-bar">
      <div class="ts-fill" style={`width:${small.progress}%; background:${small.progressColor};`}></div>
    </div>
    <div class="ts-arrow"><i class="ti ti-arrow-right" aria-hidden="true"></i></div>
  </a>
)}

<style>
  /* ── Wide card ── */
  .tw {
    display: flex;
    align-items: center;
    gap: 1.1rem;
    background: var(--bg);
    border-radius: 16px;
    padding: 1.2rem 1.4rem;
    text-decoration: none;
    position: relative;
    overflow: hidden;
    transition: opacity .15s;
  }
  .tw:hover { opacity: .88; }

  .tw-illus {
    position: absolute;
    right: 0; top: 0; bottom: 0;
    width: 45%;
    pointer-events: none;
    display: flex; align-items: center;
  }
  .tw-illus svg { width: 100%; height: 100%; }

  .tw-icon {
    width: 46px; height: 46px; border-radius: 12px;
    background: var(--ib); color: var(--ic);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.35rem; flex-shrink: 0; position: relative;
  }
  .tw-name { font-size: .95rem; font-weight: 700; color: #1a1a1a; margin-bottom: 2px; }
  .tw-desc { font-size: .78rem; color: #8a7a60; }
  .tw-body { position: relative; }
  .tw-cta {
    margin-left: auto;
    font-size: .8rem; font-weight: 600;
    color: var(--cc); border: 1.5px solid var(--cb);
    border-radius: 99px; padding: 6px 16px;
    white-space: nowrap; flex-shrink: 0; position: relative;
  }

  /* ── Small card ── */
  .ts {
    background: #fff;
    border-radius: 14px;
    padding: 1.1rem 1rem 1rem;
    text-decoration: none;
    display: flex; flex-direction: column;
    box-shadow: 0 1px 3px rgba(0,0,0,.05), 0 2px 10px rgba(0,0,0,.04);
    transition: transform .15s, box-shadow .15s;
  }
  .ts:hover {
    transform: translateY(-2px);
    box-shadow: 0 3px 8px rgba(0,0,0,.08), 0 6px 20px rgba(0,0,0,.05);
  }
  .ts-icon {
    width: 38px; height: 38px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.1rem; margin-bottom: .7rem;
  }
  .ts-name  { font-size: .88rem; font-weight: 700; color: #1a1a1a; margin-bottom: 2px; }
  .ts-desc  { font-size: .74rem; color: #999; margin-bottom: .75rem; }
  .ts-stat  { font-size: .74rem; color: #555; font-weight: 500; flex: 1; margin-bottom: .5rem; }
  .ts-bar   { height: 3px; background: #F0EDE8; border-radius: 99px; margin-bottom: .65rem; }
  .ts-fill  { height: 100%; border-radius: 99px; }
  .ts-arrow { font-size: .95rem; color: #ccc; margin-top: auto; }
  .ts:hover .ts-arrow { color: #888; }
</style>
