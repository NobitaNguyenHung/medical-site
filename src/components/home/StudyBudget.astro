---
import type { StudyBudget } from '~/data/home-config';

interface Props { budget: StudyBudget }
const { budget } = Astro.props;

const recommendationMeta = {
  'nhẹ': { icon: 'ti-leaf', label: 'nhẹ', className: 'light' },
  'vừa': { icon: 'ti-flame', label: 'vừa', className: 'moderate' },
  'nghỉ': { icon: 'ti-moon', label: 'nghỉ', className: 'rest' },
}[budget.recommendation];
---

<section class="bd" aria-labelledby="study-budget-title">
  <div class="bd-head">
    <div>
      <h2 id="study-budget-title">{budget.title}</h2>
      <p>{budget.subtitle}</p>
    </div>
    <div class={`bd-rec bd-rec-${recommendationMeta.className}`}>
      <i class={`ti ${recommendationMeta.icon}`} aria-hidden="true"></i>
      <span>Khuyến nghị: {recommendationMeta.label}</span>
    </div>
  </div>

  <div class="bd-grid">
    {budget.metrics.map(metric => (
      <div class={`bd-metric bd-${metric.tone}`}>
        <div class="bd-ico">
          <i class={`ti ${metric.icon}`} aria-hidden="true"></i>
        </div>
        <div>
          <div class="bd-value">{metric.value}</div>
          <div class="bd-label">{metric.label}</div>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .bd {
    background: #fff;
    border: 1px solid #EDE9E3;
    border-radius: 16px;
    padding: 1.1rem;
    margin-bottom: 1.75rem;
    box-shadow: 0 1px 3px rgba(0,0,0,.05), 0 6px 20px rgba(0,0,0,.035);
  }

  .bd-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .bd h2 {
    color: #1a1a1a;
    font-size: 1rem;
    line-height: 1.25;
    margin-bottom: .25rem;
  }

  .bd p {
    color: #888;
    font-size: .78rem;
    line-height: 1.45;
  }

  .bd-rec {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    min-height: 34px;
    padding: 7px 11px;
    border-radius: 99px;
    font-size: .76rem;
    font-weight: 700;
    white-space: nowrap;
  }

  .bd-rec-light {
    background: #E6F4EE;
    color: #15775B;
  }

  .bd-rec-moderate {
    background: #FAEEDA;
    color: #854F0B;
  }

  .bd-rec-rest {
    background: #E6F1FB;
    color: #185FA5;
  }

  .bd-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
  }

  .bd-metric {
    display: flex;
    align-items: center;
    gap: .75rem;
    min-width: 0;
    border-radius: 12px;
    padding: .85rem;
    background: #F7F4EF;
  }

  .bd-ico {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    font-size: 1.1rem;
  }

  .bd-value {
    color: #1a1a1a;
    font-size: 1.25rem;
    font-weight: 800;
    line-height: 1.05;
  }

  .bd-label {
    color: #777;
    font-size: .7rem;
    line-height: 1.3;
    margin-top: 3px;
  }

  .bd-warm .bd-ico { background: #FAEEDA; color: #854F0B; }
  .bd-blue .bd-ico { background: #E6F1FB; color: #185FA5; }
  .bd-green .bd-ico { background: #E6F4EE; color: #15775B; }

  @media (max-width: 700px) {
    .bd-head { flex-direction: column; }
    .bd-rec { white-space: normal; }
    .bd-grid { grid-template-columns: 1fr; }
  }
</style>
