---
interface Props {
	title?: string;
	headers?: string[];
	rows?: string[][];
}

const { title = 'Bảng phân biệt', headers, rows } = Astro.props;
const hasData = headers && rows && headers.length > 0 && rows.length > 0;
---

<section class="medical-box">
	<p class="medical-box__title">{title}</p>
	<div class="compare-table">
		{hasData ? (
			<table>
				<thead>
					<tr>
						{headers!.map((h) => <th>{h}</th>)}
					</tr>
				</thead>
				<tbody>
					{rows!.map((row) => (
						<tr>
							{row.map((cell, i) => i === 0 ? <th scope="row">{cell}</th> : <td>{cell}</td>)}
						</tr>
					))}
				</tbody>
			</table>
		) : (
			<slot />
		)}
	</div>
</section>
